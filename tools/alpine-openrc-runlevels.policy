# action	runlevel	service	target	reason
add	boot	networking	/etc/init.d/networking	Temporary Bunix networking service using ifupdown-ng and udhcpc until stock Alpine networking is restored.
replace	inittab	getty	/bin/login	Bunix login contacts the user server; BusyBox getty/login is intentionally not enabled yet.
defer	sysinit	devfs	/etc/init.d/devfs	Device filesystem is provided by the Bunix devfs server.
defer	sysinit/procfs	/proc	/etc/init.d/procfs	Procfs is provided by the Bunix procfs server and mounted through VFS.
defer	sysinit/sysfs	/sys	/etc/init.d/sysfs	Sysfs is provided by the Bunix sysfs server and mounted through VFS.
